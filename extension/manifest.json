{
  "manifest_version": 3,
  "name": "Palinso",
  "version": "1.0.0",
  "description": "Envoie des articles web à ton Kindle en un clic",

  "permissions": ["activeTab", "storage", "scripting", "tabs", "identity"],

  "host_permissions": [
    "https://palinso-production.up.railway.app/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],

  "key": "",

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Envoyer au Kindle"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["Readability.js", "content.js"]
    }
  ],

  "oauth2": {
    "client_id": "1019448349808-hlah5e5le9qa29osgnbrgqcct2d3sspe.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },

  "web_accessible_resources": [
    {
      "resources": ["auth/auth.html", "dashboard/dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}