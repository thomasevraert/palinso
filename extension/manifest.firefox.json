{
  "manifest_version": 3,
  "name": "Palinso",
  "version": "1.0.0",
  "description": "Envoie des articles web à ton Kindle en un clic",

  "browser_specific_settings": {
    "gecko": {
      "id": "palinso@palinso.app",
      "strict_min_version": "109.0"
    }
  },

  "permissions": ["activeTab", "storage", "scripting", "tabs", "identity"],

  "host_permissions": [
    "https://palinso-production.up.railway.app/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Envoyer au Kindle"
  },

  "background": {
    "service_worker": "background.js",
    "scripts": ["lib/browser-polyfill.min.js", "background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/browser-polyfill.min.js", "Readability.js", "content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["auth/auth.html", "dashboard/dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
